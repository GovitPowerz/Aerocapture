# === Miscellaneous ===
*.json
!tests/reference_data/**/*.json
# Paper results bundle (collected by experiments/paper/12_collect_results.sh):
# the *.json rule above would silently drop best_model/best_params/final_selection.
!articles/paper/data/**/*.json
*.temp
*.png
# Ignore training artifacts, EXCEPT the optimized reference trajectory:
# ref-tracking training configs point at it, so CI/e2e need it committed.
training_output/*
!training_output/mars/
training_output/mars/*
!training_output/mars/ref_trajectory.dat
data/neural_network/nn_model.json
*.pdf
.superpowers/
