c2......................................................................
c3    Ce module determine la consigne de gite du guidage lateral (techni
c3    que de renverse de roulis).
c3    On commande une renverse de roulis sur un critere de depassement
c3    d'inclinaison sur un couloir defini en fonction de la vitesse re-
c3    lative, le couloir pouvant etre de largeur constante ou decroitre
c3    lineairement du debut a la fin d'aerocapture.
c3
c3    NOTA  pour le couloir de commande de renverse de roulis, on envisa
c3          ge un couloir de la forme (V/a)**4 - i0 centre sur l'inclinai
c3          son finale a obtenir
c3......................................................................
c4    variables d'entree
c4
c4    positn(3)         R8    postion absolue courante geocentrique
c4    vitesn(3)         R8    vitesse relative locale
c4    gitlon            R8    consigne de gite longi
c4    temsim            R8    temps courant
c4......................................................................
c5    variables d'entree-sortie
c5
c5    sgngit            R8    signe de la gite commandee
c5    nbroll            I4    nombre de renverses de roulis
c5......................................................................
c6    variables de sortie
c6
c6    gitcom            R8    consigne de gite guidage longitudinal
c6    indrol            I4    indicateur de renverse
c6......................................................................
c7    variables internes
c7
c7    xinccr            R8    ecart courant sur l'inclinaison
c7    xinmax            R8    inclinaison courante sur le corridor
c7    xorbit(7)         R8    parametres orbitaux
c7......................................................................
c8    composants appelants
c8
c8    guidag           INT    guidage type predicteur-correcteur
c8......................................................................
c9    composants appeles
c9
c9    orbito           INT    calcul des parametres orbitaux
c9......................................................................
c10   commons utilises
c10
c10   corrid                  couloir de renverse de roulis
c10   modecr                  edition message ecran
c10   orbvis                  parametres orbitaux vises
c10   revers                  nombre maximal de renverses autorisees
c10   trigon
c10   vlimit                  seuil de comparaison
c10.....................................................................
c11   norme logicielle GENE S320
c11
c11   oui
c11.....................................................................
c
      subroutine  guilat (positn,vitesn,gitlon,temsim,gitpre,
     +                    sgngit,nbroll,
     +                    trevrs,indrvr,indrol)
c
      implicit none
c
      integer  nbroll,indrol,
     +         iecran,irevrs,indrvr,rolway
     
      integer nbrnrj,kinnrj,i,itable
      
      parameter (itable = 2000)
c
      double precision  positn(3),vitesn(3),gitlon,temsim,sgngit,
     +                  degrad,pi,trevrs,gitpre,
     +                  coridx,coridy,demiax,excorb,gomega,sgnpre,
     +                  vitrel,xinccr,xincli,xinmax,xorbit(13),
     +                  zapoge,zperig,epsiln,nrjval,nrjpre,nrjhdt,
     +                  nrjtst,refpre,refhdt,refhtt,refincli,
     +                  enrjlt,xinclnom,srefer,vgitmx,xmasse,tnavig,
     +                  tguida,tpilot,tpredi,tinteg,dgitcm,
     +                  enrtot
c 
      common / capsul / srefer,vgitmx,xmasse
      common / corrid / coridx,coridy
      common / modecr / iecran
      common / orbvis / zapoge,zperig,demiax,excorb,xincli,gomega
      common / period / tnavig,tguida,tpilot,tpredi,tinteg
      common / revers / irevrs
      common / trigon / degrad,pi
      common / vlimit / epsiln
      common / rolchg / rolway
      
      common / tabnrj / nrjval(itable), nrjpre(itable),nrjhdt(itable),
     +                  nrjtst(itable)
      common / reftab / refpre(itable), refhdt(itable),refhtt(itable),
     +                  refincli(itable)
      common / colnrj / nbrnrj
c
      if ((gitlon.ne.0.d0).and.(gitlon.ne.pi)) then
c
         sgnpre = sgngit
c
c		calcul des parametres orbitaux
c
         call  orbito (positn,vitesn,
     +                 xorbit)
c
         xinccr = xorbit(3)
         vitrel = vitesn(1)
c         
         indrol = 0
c
c		position courante dans le corridor de gudage lateral
c
         xinccr =  xincli - xinccr
         
         if (positn(3).lt.0.d0) then
            xinccr = -xinccr
         endif
c
c	 xinmax = coridy
	 xinmax = (vitrel/coridx)**4 + coridy
c
         if ((dabs(xinccr).ge.xinmax).and.
     +       (dabs(gitlon).gt.epsiln)) then
c
            if (nbroll.lt.irevrs) then
c
c		sortie du couloir
c
               if (xinccr.gt.xinmax) then
                  sgngit = -1.d0
               else
                  if (xinccr.lt.(-xinmax)) then
                     sgngit = 1.d0
                  endif
               endif
c
	       if ((sgngit*sgnpre).lt.0.d0) then
c
c		commande d'une renverse en roulis
c
                  indrol = 1
                  nbroll = nbroll + 1
                  
                  if (iecran.eq.1) then
                     write(6,1000) temsim
                  endif
                  if (indrvr.eq.0) then
                     indrvr = 1
                     indrvr = 0
c		     if ((dabs(gitpre)+dabs(gitlon)).le.pi) then
		     	rolway=1
                     	dgitcm = dabs(gitpre) + dabs(gitlon)
c                     	write(6,*) gitlon/degrad,gitpre/degrad,
c     +                             dgitcm/degrad,rolway
                     	trevrs = dgitcm/vgitmx
                     	trevrs = dint(trevrs/tguida)*tguida
c                     else
c                     	rolway=-1
c                     	dgitcm = 2*pi-dabs(gitpre) - dabs(gitlon)
c                     	write(6,*) gitlon/degrad,gitpre/degrad,
c     +                             dgitcm/degrad,rolway
c                       	trevrs = dgitcm/vgitmx
c                     	trevrs = dint(1. d0 + trevrs/tguida)*tguida
c                     endif
                  endif
c
               endif
c
            endif
         endif
	
c 	 write(6,*)'delta inclinaison =',xinccr/degrad
c 	 write(6,*)'xinmax =',xinmax/degrad
c 	 write(6,*)'sgngit =',sgngit

      endif
      
      
c
 1000 format(1x,'roll reversal a T : ',f8.3,' s')
c
      return
      end
